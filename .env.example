# ═══════════════════════════════════════════════════════════════
# Starknet NFT Ticketing — Environment Variables
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketing

# ── Redis ─────────────────────────────────────────────────────
# Redis URL for caching and BullMQ job queue
REDIS_URL=redis://localhost:6379

# ── Starknet ──────────────────────────────────────────────────
# RPC endpoint (Alchemy, Infura, or public)
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_7/demo
# Network: sepolia or mainnet
STARKNET_NETWORK=sepolia
# Deployer account private key (hex with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x...
# Deployer account address (hex with 0x prefix)
DEPLOYER_ADDRESS=0x...

# ── Contracts (filled after deployment via deploy.ts) ─────────
# TicketFactory contract address
FACTORY_ADDRESS=0x...
# Marketplace contract address
MARKETPLACE_ADDRESS=0x...

# ── AVNU Paymaster (gas sponsoring via StarkZap) ──────────────
# AVNU paymaster endpoint
AVNU_PAYMASTER_URL=https://starknet.paymaster.avnu.fi
# Max sponsored transactions per user per day
MAX_SPONSORED_TXS_PER_DAY=20

# ── Stripe ────────────────────────────────────────────────────
# Stripe secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Authentication ────────────────────────────────────────────
# JWT signing secret (min 32 characters, use a random string)
JWT_SECRET=change-me-in-production-min-32-chars
# HMAC key for QR code signatures (min 32 characters)
QR_SIGNING_PRIVATE_KEY=change-me-min-32-chars

# ── Bridge (Digital Twin) ─────────────────────────────────────
# Vault address for bridged tickets (defaults to DEPLOYER_ADDRESS)
# VAULT_ADDRESS=0x...

# ── Indexer ──────────────────────────────────────────────────
# Polling interval in milliseconds (default: 5000)
# INDEXER_POLL_MS=5000

# ── Server ────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
# development | staging | production
NODE_ENV=production
# debug | info | warn | error
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────
# Frontend URL allowed for CORS (required in production)
FRONTEND_URL=https://your-domain.com

# ── Frontend (Next.js public vars) ────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api-domain.com
NEXT_PUBLIC_STARKNET_NETWORK=sepolia
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x...

# ── Docker Compose ────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production
