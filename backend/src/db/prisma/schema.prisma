generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizer {
  id              String   @id @default(uuid())
  name            String
  treasuryAddress String
  avnuApiKey      String?
  apiKey          String   @unique
  createdAt       DateTime @default(now())
  events          Event[]
  bridgedTickets  BridgedTicket[]
}

model Event {
  id              String       @id @default(uuid())
  organizerId     String
  organizer       Organizer    @relation(fields: [organizerId], references: [id])
  contractAddress String       @unique
  name            String
  eventDate       DateTime
  maxSupply       Int
  primaryPrice    BigInt       @default(1000000)
  resaleCapBps    Int          @default(11000)
  royaltyBps      Int          @default(1000)
  metadataBaseUri String?
  isSoulbound          Boolean      @default(false)
  maxTransfers         Int          @default(0)
  paymentTokenAddress  String?
  acceptedCurrencies   String[]     @default(["STRK"])
  createdAt            DateTime     @default(now())
  tickets              Ticket[]
  pendingMints         PendingMint[]
  bridgedTickets       BridgedTicket[]
}

model Ticket {
  id                  String       @id @default(uuid())
  eventId             String
  event               Event        @relation(fields: [eventId], references: [id])
  tokenId             BigInt
  ownerAddress        String
  ownerEmail          String?
  status              TicketStatus @default(AVAILABLE)
  transferCount       Int          @default(0)
  lastTransactionHash String?
  updatedAt           DateTime     @updatedAt
  scanLogs            ScanLog[]
  listings            Listing[]
  bridgedTicket       BridgedTicket?

  @@unique([eventId, tokenId])
  @@index([ownerAddress])
  @@index([eventId, status])
  @@index([status])
}

enum TicketStatus {
  AVAILABLE
  LISTED
  USED
  CANCELLED
  REVOKED
}

model Listing {
  id               String   @id @default(uuid())
  ticketId         String
  ticket           Ticket   @relation(fields: [ticketId], references: [id])
  sellerAddress    String
  price            Decimal
  isActive         Boolean  @default(true)
  onChainListingId BigInt?
  createdAt        DateTime @default(now())

  @@index([isActive, createdAt])
}

model ScanLog {
  id                  String     @id @default(uuid())
  ticketId            String
  ticket              Ticket     @relation(fields: [ticketId], references: [id])
  scannedAt           DateTime   @default(now())
  scannerStaffId      String?
  gateId              String?
  isOfflineValidation Boolean    @default(false)
  syncStatus          SyncStatus @default(PENDING)

  @@index([ticketId, syncStatus])
}

enum SyncStatus {
  PENDING
  SYNCED
}

model PendingMint {
  id                    String   @id @default(uuid())
  eventId               String
  event                 Event    @relation(fields: [eventId], references: [id])
  stripePaymentIntentId String?  @unique
  buyerEmail            String
  buyerWalletAddress    String?
  status                String   @default("PENDING")
  txHash                String?
  cryptoTxHash          String?  @unique
  paymentAmount         BigInt?
  paymentCurrency       String?
  createdAt             DateTime @default(now())
}

enum BridgedTicketStatus {
  PENDING
  MINTED
  CLAIMING
  CLAIMED
  FAILED
}

model BridgedTicket {
  id                String              @id @default(uuid())
  externalTicketId  String
  externalProvider  String              @default("generic")
  eventId           String
  event             Event               @relation(fields: [eventId], references: [id])
  organizerId       String
  organizer         Organizer           @relation(fields: [organizerId], references: [id])
  ownerEmail        String
  passType          String?
  externalMetadata  Json?
  tokenId           BigInt?
  ticketId          String?             @unique
  ticket            Ticket?             @relation(fields: [ticketId], references: [id])
  vaultAddress      String?
  claimedByAddress  String?
  status            BridgedTicketStatus @default(PENDING)
  mintTxHash        String?
  claimTxHash       String?
  errorMessage      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([externalTicketId, organizerId])
  @@index([ownerEmail, status])
  @@index([eventId, status])
}
